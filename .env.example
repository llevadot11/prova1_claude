# Anthropic API key for explanation generation (Claude Haiku 4.5)
ANTHROPIC_API_KEY=

# Open-Meteo (no key required)
OPEN_METEO_FORECAST_URL=https://api.open-meteo.com/v1/forecast
OPEN_METEO_AQ_URL=https://air-quality-api.open-meteo.com/v1/air-quality

# Open Data BCN — TRAMS dataset id (update each month)
OD_BCN_TRAMS_RESOURCE=https://opendata-ajuntament.barcelona.cat/data/dataset/trams/resource/0ed5dfa6-4071-4e0e-a6b7-4a1dc647b50b/download/2026_05_Maig_TRAMS_TRAMS.csv

# Demo fallback: when set to 1, API serves only from data/processed/ufi_latest.parquet
# and the pre-cooked snapshot. Cuts off all upstream calls.
DEMO_OFFLINE=0

# Paths (relative to repo root)
DATA_DIR=data
PROCESSED_DIR=data/processed
CACHE_DIR=data/cache

# Railway deployment URL (set when deployed — A uses this for VITE_API_BASE_URL)
RAILWAY_URL=

# CORS: comma-separated allowed origins. Default "*" for local dev.
# In production: CORS_ORIGINS=https://ufi-bcn.vercel.app
CORS_ORIGINS=*

# Frontend (local dev)
VITE_API_BASE_URL=http://localhost:8000
